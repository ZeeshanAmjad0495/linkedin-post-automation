<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd schedule for the LinkedIn auto-poster (macOS).
  Placeholders __PROJECT_DIR__ are filled in by scripts/install_launchd.sh.

  Default: once per day at 09:30 local time.
  To post every 6 hours instead, replace the StartCalendarInterval block with:
      <key>StartInterval</key><integer>21600</integer>
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zeeshan.linkedin-autopost</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/scripts/run_once.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>9</integer>
        <key>Minute</key><integer>30</integer>
    </dict>

    <!-- If the Mac was asleep at the scheduled time, run as soon as it wakes. -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/logs/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/logs/launchd.err.log</string>
</dict>
</plist>
