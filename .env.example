# Copy to .env and fill in. See README for how to obtain each value.
# Keep comments on their own lines (trailing comments can be parsed into values).
POST_BACKEND=browser
BROWSER_HEADLESS=true
BROWSER_CHANNEL=

LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/callback
POST_VISIBILITY=PUBLIC

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

IMAGE_MODE=mix
IMAGE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

BRAND_NAME=
BRAND_HANDLE=

DRY_RUN=true
